package com.art_gallery.enitiy;

import jakarta.persistence.*;
import lombok.Data;

import java.time.LocalDate;
import java.time.LocalDateTime;

import com.art_gallery.enitiy.Artwork;
import com.art_gallery.enitiy.User;

@Entity
@Table(name = "orders")
@Data
public class Order {

    public enum Status {
        pending, approved, rejected, shipped, delivered
    }

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Integer id;

    @ManyToOne
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    @ManyToOne
    @JoinColumn(name = "artwork_id", nullable = false)
    private Artwork artwork;

    @Column(name = "order_date", nullable = false)
    private LocalDate orderDate;

    @Enumerated(EnumType.STRING)
    @Column(columnDefinition = "ENUM('pending','approved','rejected','shipped','delivered') default 'pending'")
    private Status status = Status.pending;

    @Column(name = "created_at")
    private LocalDateTime createdAt;
}
