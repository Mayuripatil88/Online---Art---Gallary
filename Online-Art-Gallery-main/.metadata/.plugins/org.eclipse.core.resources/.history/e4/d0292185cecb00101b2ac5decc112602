package com.art_gallery.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.art_gallery.enitiy.Artwork;
import com.art_gallery.serviceImpl.ArtworkServiceImpl;

@RestController
@RequestMapping("/api/artworks")
public class ArtworkController {

    @Autowired
    private ArtworkServiceImpl artworkService;

    @GetMapping
    public List<Artwork> getAll() {
        return artworkService.getAllArtworks();
    }

    @PostMapping
    public Artwork create(@RequestBody Artwork artwork) {
        return artworkService.createArtwork(artwork);
    }
}
